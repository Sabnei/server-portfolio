# ── PostgreSQL central ───────────────────────────────────────────────
POSTGRES_USER=portfolio_admin
POSTGRES_PASSWORD=cambia_esto
POSTGRES_DB=portfolio

# ── Airflow UI ───────────────────────────────────────────────────────
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=cambia_esto_tambien
AIRFLOW_FIRSTNAME=Admin
AIRFLOW_LASTNAME=User
AIRFLOW_EMAIL=admin@portfolio.local

# ── pgAdmin ──────────────────────────────────────────────────────────
PGADMIN_EMAIL=admin@portfolio.local
PGADMIN_PASSWORD=pgadmin_password

# ── Variables que leen todos los DAGs para conectarse a Postgres ─────
# El host es "postgres-central" porque ese es el nombre del contenedor
# dentro de la red Docker. Nunca uses "localhost" desde Airflow.
DB_HOST=postgres-central
DB_PORT=5432
DB_USER=portfolio_admin
DB_PASSWORD=cambia_esto
DB_NAME=portfolio
